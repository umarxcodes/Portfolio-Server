NODE_ENV=development
PORT=5000

MONGO_URI=mongodb://127.0.0.1:27017/portfolio-cms
MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=0
MONGO_CONNECT_RETRIES=3
MONGO_CONNECT_RETRY_DELAY_MS=2000

ACCESS_TOKEN_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_EXPIRES_IN=24h
BCRYPT_SALT_ROUNDS=12

JSON_BODY_LIMIT=1mb
URL_ENCODED_BODY_LIMIT=1mb
TRUST_PROXY=false

CLIENT_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

UPLOAD_ROOT=uploads
UPLOAD_STORAGE_DRIVER=local
BLOB_READ_WRITE_TOKEN=
IMAGE_UPLOAD_MAX_MB=5
PDF_UPLOAD_MAX_MB=10

GLOBAL_RATE_LIMIT_WINDOW_MS=60000
GLOBAL_RATE_LIMIT_MAX=100
CONTACT_RATE_LIMIT_WINDOW_MS=3600000
CONTACT_RATE_LIMIT_MAX=5

LOG_LEVEL=info

ADMIN_NAME=Portfolio Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
